{
	"name": "geary-indicator",
	"version": "0.0.0",
	"author": "hallelujahdrive",
	"main": "extension.js",
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@eslint/js": "^10.0.1",
		"@girs/gio-2.0": "2.86.4-4.0.0-beta.40",
		"@girs/gjs": "4.0.0-beta.38",
		"@girs/glib-2.0": "2.86.0-4.0.0-beta.38",
		"@girs/gnome-shell": "^49.1.0",
		"@girs/gobject-2.0": "2.86.0-4.0.0-beta.38",
		"@typescript-eslint/parser": "^8.57.1",
		"eslint-plugin-perfectionist": "^5.7.0",
		"husky": "^9.1.7",
		"rolldown": "^1.0.0-rc.10",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.1"
	},
	"description": "Geary Indicator is a GNOME Shell extension that adds a Geary's indicator to the panel.",
	"license": "GPL-3.0-only",
	"scripts": {
		"build": "rolldown -c",
		"check": "biome check . && eslint .",
		"check:fix": "biome check --write . && eslint . --fix",
		"format": "biome format . && eslint .",
		"format:fix": "biome format --write . && eslint . --fix",
		"lint": "biome lint . && eslint .",
		"lint:fix": "biome lint --write . && eslint . --fix",
		"test": "echo \"Error: no test specified\" && exit 1",
		"typecheck": "tsc --noEmit --pretty",
		"prepare": "husky"
	},
	"type": "module"
}
